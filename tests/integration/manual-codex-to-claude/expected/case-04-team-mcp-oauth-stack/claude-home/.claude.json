{
  "mcpServers": {
    "github": {
      "url": "https://mcp.github.com"
    },
    "linear": {
      "url": "https://mcp.linear.app"
    },
    "sentry": {
      "url": "https://mcp.sentry.io",
      "env": {
        "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}"
      }
    },
    "postgres": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/postgres"
      ],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    }
  }
}
