{
  "mcpServers": {
    "manual_github": {
      "type": "http",
      "url": "https://mcp.github.com"
    },
    "manual_linear": {
      "type": "http",
      "url": "https://mcp.linear.app"
    },
    "manual_sentry": {
      "type": "http",
      "url": "https://mcp.sentry.io",
      "headers": {
        "Authorization": "Bearer ${SENTRY_AUTH_TOKEN}"
      }
    },
    "manual_postgres": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/postgres"
      ],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    }
  }
}
