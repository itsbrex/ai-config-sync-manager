{
  "name": "ai-config-sync-manager",
  "version": "0.1.0-beta.0",
  "private": false,
  "packageManager": "npm@11.9.0",
  "description": "OSS manager for syncing Claude and Codex developer configuration.",
  "author": {
    "name": "Maxx",
    "email": "slash9494@gmail.com"
  },
  "maintainers": [
    {
      "name": "Maxx",
      "email": "slash9494@gmail.com"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/slash9494/ai-config-sync-manager/",
  "type": "module",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "codex",
    "config",
    "config-sync",
    "developer-tools",
    "mcp",
    "plugin",
    "skills"
  ],
  "bin": {
    "ai-config-sync": "./bin/ai-config-sync.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slash9494/ai-config-sync-manager.git"
  },
  "files": [
    "bin/",
    "dist/",
    "integrations/",
    "rules/",
    "schemas/",
    "scripts/build-dist.mjs",
    "scripts/sync-plugin-cache.mjs",
    "scripts/lib/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "husky && node scripts/build-dist.mjs --skip-sync",
    "build:dist": "node scripts/build-dist.mjs",
    "build:dist:no-sync": "node scripts/build-dist.mjs --skip-sync",
    "check": "tsc -p tsconfig.check.json",
    "refresh:cache": "node scripts/refresh-cache.mjs",
    "snapshot:upstream": "node scripts/snapshot-upstream.mjs",
    "test": "node --test tests/*.test.mjs tests/integration/codex-to-claude/*.test.mjs",
    "test:manual:reset": "tests/integration/manual-codex-to-claude/scripts/reset.sh",
    "test:manual:run": "tests/integration/manual-codex-to-claude/scripts/run-cases.sh",
    "test:set-home": "tests/integration/manual-codex-to-claude/scripts/set-home-to-test-lab.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:setup": "npm link && npm run build:dist",
    "dev:teardown": "npm unlink -g ai-config-sync-manager"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.2"
  },
  "lint-staged": {
    "*.{js,mjs,json,md,yml,yaml}": [
      "prettier --list-different"
    ],
    "*.{js,mjs}": [
      "eslint"
    ]
  }
}
