{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@ai-config-sync-manager/core": ["../core/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true
  },
  "references": [
    {
      "path": "../core"
    }
  ],
  "include": ["src/**/*.ts"]
}
