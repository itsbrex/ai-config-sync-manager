{
  "source": "codex",
  "target": "claude",
  "areas": {
    "instructions": {
      "risk": "safe",
      "mapping": "AGENTS.md to CLAUDE.md"
    },
    "skills": {
      "risk": "safe",
      "mapping": "Codex skills to Claude skills",
      "policy": {
        "missingInTarget": "copy",
        "sameNameDifferentContent": "manual-conflict",
        "delete": "not-in-mvp",
        "overwrite": "not-in-mvp"
      }
    },
    "mcp": {
      "risk": "safe",
      "mapping": "Codex [mcp_servers.*] tables to Claude mcpServers"
    },
    "permissions": {
      "risk": "manual",
      "mapping": "Codex web_search, prefix_rule, sandbox, MCP enabled/disabled tools, and MCP tool approvals to Claude permissions where reversible",
      "nativeSources": {
        "web_search = live": "WebSearch allow",
        "rules/default.rules prefix_rule": "Bash(<pattern>) allow/ask/deny",
        "mcp_servers.<server>.enabled_tools": "mcp__server__tool allow",
        "mcp_servers.<server>.disabled_tools": "mcp__server__tool deny",
        "mcp_servers.<server>.tools.<tool>.approval_mode": "mcp__server__tool allow/ask/deny",
        "sandbox_mode = workspace-write": "Write/Edit/MultiEdit allow",
        "sandbox_workspace_write.network_access = true": "WebFetch review item"
      }
    },
    "hooks": {
      "risk": "manual",
      "mapping": "Codex native command hooks to Claude hooks where event/handler is reversible"
    },
    "commands": {
      "risk": "partial",
      "mapping": "Codex skills or scripts may become Claude slash commands; conversion remains manual-review until the source command intent is confirmed"
    }
  }
}
